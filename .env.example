# Optional. Enable OCR fallback for scanned PDFs. Requires local Tesseract installation.
CUET_ENABLE_OCR=false

# Optional. The default pipeline is local/rule-based; add a key to enable capped LLM classification.
OPENAI_API_KEY=

# Optional. Used by scripts/classify_ensemble.py when a provider key is present.
# Hack Club AI is OpenAI-compatible.
HACKCLUB_AI_API_KEY=
CUET_LLM_API_KEY=
CUET_LLM_BASE_URL=https://ai.hackclub.com/proxy/v1
CUET_LLM_MODEL=~openai/gpt-mini-latest
CUET_LLM_FALLBACK_MODELS=~anthropic/claude-haiku-latest,~google/gemini-flash-latest,ibm-granite/granite-4.1-8b
CUET_LLM_MODE=ambiguous
CUET_LLM_MAX_CALLS=100
CUET_LLM_MAX_TOKENS=180

# Optional. Default is false so the pipeline stays runnable without model downloads.
CUET_USE_SENTENCE_TRANSFORMERS=false
CUET_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional. Enables Google's TimesFM model on the CUET CS dashboard forecast page.
# Requires `pip install -r requirements-timesfm.txt` and may download a large checkpoint.
CUET_USE_TIMESFM=false
CUET_TIMESFM_MODEL=google/timesfm-2.5-200m-pytorch
CUET_TIMESFM_MAX_CONTEXT=1024
CUET_TIMESFM_MAX_HORIZON=32

# Optional legacy collector keys retained from the existing workspace.
GITHUB_TOKEN=
PRODUCT_HUNT_TOKEN=
X_USERNAME=
X_EMAIL=
X_PASSWORD=
